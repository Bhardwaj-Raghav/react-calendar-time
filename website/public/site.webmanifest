{
  "name": "react-calendar-time",
  "short_name": "Calendar Time",
  "description": "Accessible React date and time picker",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#f3f6ef",
  "theme_color": "#3f6a28",
  "icons": [
    {
      "src": "/apple-touch-icon.png",
      "sizes": "512x512",
      "type": "image/png"
    },
    {
      "src": "/favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml"
    }
  ]
}
